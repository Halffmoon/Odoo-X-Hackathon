# --- Database (Neon DB pooled connection string) ---
# Use the asyncpg driver. Append the pooled host. SSL is required for Neon.
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<neon-pooler-host>/<db>?ssl=require

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- File uploads ---
UPLOAD_DIR=uploads
